---
const currentYear = new Date().getFullYear();
---

<footer class="bg-green-900 text-white">
  <div class="max-w-6xl mx-auto px-6 pt-12 pb-8">

    <!-- Top section: 3-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 mb-10">

      <!-- Column 1: Brand -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <a href="/" aria-label="North Country Lawn & Landscape - Home" class="inline-flex items-center gap-2 mb-4">
          <svg class="w-8 h-8 text-green-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          <span class="font-bold text-lg text-white leading-snug">North Country Lawn & Landscape</span>
        </a>
        <p class="text-green-200 text-sm">Littleton, New Hampshire</p>
        <p class="text-green-300 text-sm mt-1">Licensed & Insured</p>
      </div>

      <!-- Column 2: Contact -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Contact Us</h2>
        <ul class="space-y-2">
          <li>
            <a href="tel:+16035550142" class="text-green-200 text-sm hover:text-white transition-colors">
              (603) 555-0142
            </a>
          </li>
          <li>
            <a href="mailto:hello@example.com" class="text-green-200 text-sm hover:text-white transition-colors">
              hello@example.com
            </a>
          </li>
          <li class="text-green-200 text-sm pt-1">
            Littleton, NH and surrounding areas
          </li>
        </ul>
      </div>

      <!-- Column 3: Hours -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <h2 class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Hours</h2>
        <ul class="space-y-1 text-sm text-green-200">
          <li class="flex justify-center md:justify-start gap-4">
            <span class="w-28">Mon – Fri</span>
            <span>7am – 6pm</span>
          </li>
          <li class="flex justify-center md:justify-start gap-4">
            <span class="w-28">Saturday</span>
            <span>8am – 4pm</span>
          </li>
          <li class="flex justify-center md:justify-start gap-4">
            <span class="w-28">Sunday</span>
            <span>Closed</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Divider -->
    <hr class="border-green-700 mb-6" />

    <!-- Bottom bar: nav + copyright -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap justify-center gap-6">
          <li><a href="/" class="text-sm text-green-200 hover:text-white transition-colors">Home</a></li>
          <li><a href="/services" class="text-sm text-green-200 hover:text-white transition-colors">Services</a></li>
          <li><a href="/contact" class="text-sm text-green-200 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </nav>
      <p class="text-sm text-green-300">&copy; {currentYear} North Country Lawn & Landscape. All rights reserved.</p>
    </div>

  </div>
</footer>