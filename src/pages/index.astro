---
import Layout from '../layouts/Layout.astro';
---

<Layout title="North Country Lawn & Landscape | Littleton, NH">
  <!-- Header -->
  <!-- Header -->
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label="North Country Lawn & Landscape - Home">
        <svg class="w-8 h-8 text-green-700" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <span class="font-bold text-lg text-green-800">North Country Lawn & Landscape</span>
      </a>
      <nav aria-label="Main navigation" class="hidden md:flex items-center gap-6">
        <a href="/" class="text-green-700 font-medium">Home</a>
        <a href="/services" class="text-gray-600 hover:text-green-700">Services</a>
        <a href="/contact" class="text-gray-600 hover:text-green-700">Contact</a>
      </nav>
      <button id="menu-btn" aria-label="Open navigation menu" class="md:hidden flex flex-col gap-1.5 p-2">
        <span class="block w-6 h-0.5 bg-green-800"></span>
        <span class="block w-6 h-0.5 bg-green-800"></span>
        <span class="block w-6 h-0.5 bg-green-800"></span>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white px-4 py-4 flex flex-col gap-4">
      <a href="/" class="text-green-700 font-medium">Home</a>
      <a href="/services" class="text-gray-600 hover:text-green-700">Services</a>
      <a href="/contact" class="text-gray-600 hover:text-green-700">Contact</a>
    </div>
  </header>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>

  <main>
    <!-- Hero Section -->
<section 
  class="relative text-white"
  style="background-image: url('/lawn.jpg'); background-size: cover; background-position: center; background-color: rgb(20, 83, 45);"
>
  <div class="absolute inset-0 bg-green-900/60"></div>
  <div class="relative max-w-6xl mx-auto px-4 py-24 md:py-36 text-center">
    <h1 class="text-3xl md:text-5xl font-bold mb-4">
      North Country Lawn & Landscape
    </h1>
    <p class="text-lg md:text-xl text-green-100 mb-8">
      Proudly Serving the North Country
    </p>
    
      <a href="/services"
      class="inline-block bg-white text-green-800 font-semibold px-8 py-3 rounded-md hover:bg-gray-100"
    >
      View Our Services
    </a>
  </div>
</section>

    <!-- Why Choose Us Section -->
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-4 py-16 md:py-20">
        <h2 class="text-2xl md:text-3xl font-bold text-green-800 text-center mb-12">
          Why Choose Us
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Licensed & Insured -->
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 mb-2">Licensed & Insured</h3>
            <p class="text-gray-600 text-sm">
              Fully licensed and insured for your peace of mind and protection.
            </p>
          </div>

          <!-- Free Estimates -->
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 mb-2">Free Estimates</h3>
            <p class="text-gray-600 text-sm">
              Get a free, no-obligation estimate for any project big or small.
            </p>
          </div>

          <!-- Local & Trusted -->
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 mb-2">Local & Trusted</h3>
            <p class="text-gray-600 text-sm">
              Proudly serving Littleton, NH and surrounding communities.
            </p>
          </div>

          <!-- Reliable & On Time -->
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-800 mb-2">Reliable & On Time</h3>
            <p class="text-gray-600 text-sm">
              Count on us to show up when we say we will, every time.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-800">
      <div class="max-w-6xl mx-auto px-4 py-16 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
          Ready to Transform Your Yard?
        </h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="tel:6035550142"
            class="inline-flex items-center gap-2 bg-white text-green-800 font-semibold px-6 py-3 rounded-md hover:bg-gray-100"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            (603) 555-0142
          </a>
          <a
            href="/contact"
            class="inline-block border-2 border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-white hover:text-green-800"
          >
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-100 border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-8 text-center">
      <p class="text-gray-600 text-sm">
        &copy; 2026 North Country Lawn & Landscape. All rights reserved.
      </p>
      <p class="text-gray-500 text-sm mt-1">
        Serving Littleton, NH and the North Country
      </p>
    </div>
  </footer>
</Layout>
