  <style>
    @keyframes mowAcross {
      0%   { left: -90px;  }
      100% { left: 100%;   }
    }
    @keyframes walkLegs {
      0%   { transform: skewX(-10deg); }
      100% { transform: skewX(10deg);  }
    }
    @media (prefers-reduced-motion: reduce) {
      [style*="mowAcross"], [style*="walkLegs"] {
        animation: none;
      }
    }
