---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | North Country Lawn & Landscape" description="Get in touch with North Country Lawn & Landscape for a free estimate on lawn care and landscaping services in Littleton, NH.">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label="North Country Lawn & Landscape - Home">
        <svg class="w-8 h-8 text-green-700" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <span class="font-bold text-lg text-green-800">North Country Lawn & Landscape</span>
      </a>
      <nav aria-label="Main navigation" class="hidden md:flex items-center gap-6">
        <a href="/" class="text-gray-600 hover:text-green-700">Home</a>
        <a href="/services" class="text-gray-600 hover:text-green-700">Services</a>
        <a href="/contact" class="text-green-700 font-medium">Contact</a>
      </nav>
      <button id="menu-btn" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobile-menu" class="md:hidden flex flex-col gap-1.5 p-2">
        <span class="block w-6 h-0.5 bg-green-800"></span>
        <span class="block w-6 h-0.5 bg-green-800"></span>
        <span class="block w-6 h-0.5 bg-green-800"></span>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white px-4 py-4 flex flex-col gap-4">
      <a href="/" class="text-gray-600 hover:text-green-700">Home</a>
      <a href="/services" class="text-gray-600 hover:text-green-700">Services</a>
      <a href="/contact" class="text-green-700 font-medium">Contact</a>
    </div>
  </header>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu?.classList.toggle('hidden');
    });
  </script>

  <main>
    <!-- Page Header -->
    <section class="bg-green-800 relative overflow-hidden">

      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <style>
          @keyframes emailFly {
            /* Zoom in fast from left */
            0%   { transform: translateX(-120px) translateY(0px)   rotate(-10deg) scale(0.5); opacity: 0; }
            8%   { transform: translateX(-20px)  translateY(0px)   rotate(-5deg)  scale(1);   opacity: 1; }

            /* Settle and pause center-left */
            14%  { transform: translateX(0px)    translateY(0px)   rotate(0deg)   scale(1);   opacity: 1; }
            18%  { transform: translateX(0px)    translateY(0px)   rotate(0deg)   scale(1);   opacity: 1; }

            /* Swing up and over the top of the text */
            30%  { transform: translateX(60px)   translateY(-55px) rotate(15deg)  scale(1);   opacity: 1; }
            42%  { transform: translateX(140px)  translateY(-40px) rotate(25deg)  scale(1);   opacity: 1; }

            /* Come back down on the right side */
            54%  { transform: translateX(180px)  translateY(0px)   rotate(10deg)  scale(1);   opacity: 1; }

            /* Settle and pause center-right */
            60%  { transform: translateX(200px)  translateY(0px)   rotate(0deg)   scale(1);   opacity: 1; }
            68%  { transform: translateX(200px)  translateY(0px)   rotate(0deg)   scale(1);   opacity: 1; }

            /* Wiggle like it's about to launch */
            72%  { transform: translateX(195px)  translateY(2px)   rotate(-3deg)  scale(1);   opacity: 1; }
            76%  { transform: translateX(205px)  translateY(-2px)  rotate(3deg)   scale(1);   opacity: 1; }
            80%  { transform: translateX(200px)  translateY(0px)   rotate(0deg)   scale(1);   opacity: 1; }

            /* Shoot off to the right fast */
            88%  { transform: translateX(420px)  translateY(-20px) rotate(15deg)  scale(0.7); opacity: 0.4; }
            95%  { transform: translateX(600px)  translateY(-40px) rotate(20deg)  scale(0.3); opacity: 0; }
            100% { transform: translateX(600px)  translateY(-40px) rotate(20deg)  scale(0.3); opacity: 0; }
          }

          /* Speed lines that appear when it shoots off */
          @keyframes speedLine {
            0%   { opacity: 0; transform: scaleX(0); }
            80%  { opacity: 0; transform: scaleX(0); }
            85%  { opacity: 0.5; transform: scaleX(1); }
            95%  { opacity: 0; transform: scaleX(1.5); }
            100% { opacity: 0; transform: scaleX(0); }
          }

          .email-envelope {
            position: absolute;
            left: calc(50% - 220px);
            top: 50%;
            margin-top: -20px;
            width: 48px;
            height: 48px;
            animation: emailFly 5s ease-in-out infinite;
          }

          .speed-line {
            position: absolute;
            left: calc(50% + 10px);
            height: 2px;
            background: #86efac;
            border-radius: 9999px;
            transform-origin: left center;
            animation: speedLine 5s ease-in-out infinite;
          }
          .speed-line-1 { top: calc(50% - 6px); width: 60px; animation-delay: 0s;     }
          .speed-line-2 { top: calc(50%);        width: 40px; animation-delay: 0.05s;  }
          .speed-line-3 { top: calc(50% + 6px);  width: 50px; animation-delay: 0.1s;  }

          @media (prefers-reduced-motion: reduce) {
            .email-envelope, .speed-line { animation: none; opacity: 0; }
          }
        </style>

        <!-- Speed lines -->
        <div class="speed-line speed-line-1"></div>
        <div class="speed-line speed-line-2"></div>
        <div class="speed-line speed-line-3"></div>

        <!-- Envelope SVG -->
        <div class="email-envelope">
          <svg viewBox="0 0 48 48" width="48" height="48" xmlns="http://www.w3.org/2000/svg">
            <!-- Envelope body -->
            <rect x="2" y="10" width="44" height="30" rx="3" fill="#dcfce7" />
            <!-- Envelope flap open -->
            <path d="M2 10 L24 27 L46 10" fill="none" stroke="#15803d" stroke-width="2" stroke-linejoin="round" />
            <!-- Envelope sides -->
            <line x1="2"  y1="40" x2="18" y2="25" stroke="#15803d" stroke-width="1.5" stroke-linecap="round" />
            <line x1="46" y1="40" x2="30" y2="25" stroke="#15803d" stroke-width="1.5" stroke-linecap="round" />
            <!-- Letter peeking out -->
            <rect x="14" y="6" width="20" height="16" rx="2" fill="white" />
            <line x1="18" y1="11" x2="30" y2="11" stroke="#86efac" stroke-width="1.5" stroke-linecap="round" />
            <line x1="18" y1="15" x2="30" y2="15" stroke="#86efac" stroke-width="1.5" stroke-linecap="round" />
            <line x1="18" y1="19" x2="26" y2="19" stroke="#86efac" stroke-width="1.5" stroke-linecap="round" />
          </svg>
        </div>
      </div>

      <div class="relative max-w-6xl mx-auto px-4 py-16 md:py-20 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Contact Us
        </h1>
        <p class="text-green-100 text-lg max-w-2xl mx-auto text-pretty">
          Get in touch for a free estimate.
        </p>
      </div>
    </section>

    <!-- Contact Form Section -->
    <section class="bg-gray-50 border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-4 py-16 md:py-20">
        <div class="text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-green-800 mb-3">Send Us a Message</h2>
          <p class="text-gray-600">Fill out the form below and we'll get back to you as soon as possible.</p>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 md:p-10">
          <form action="#" method="POST" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">

              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name <span class="text-red-500" aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  placeholder="Jane Smith"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-md text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent transition"
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  placeholder="(603) 555-0100"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-md text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent transition"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address <span class="text-red-500" aria-hidden="true">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="jane@example.com"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-md text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent transition"
                />
              </div>

              <!-- Service -->
              <div>
                <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Interested In</label>
                <select
                  id="service"
                  name="service"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-md text-gray-800 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent transition bg-white"
                >
                  <option value="" disabled selected>Select a service...</option>
                  <option value="mowing">Lawn Mowing & Maintenance</option>
                  <option value="cleanup">Spring & Fall Cleanup</option>
                  <option value="mulching">Mulching & Bed Work</option>
                  <option value="shrubs">Shrub & Bush Trimming</option>
                  <option value="seeding">Loam & Seeding</option>
                  <option value="snow">Snow Removal</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <!-- Message -->
            <div class="mb-8">
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500" aria-hidden="true">*</span></label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Tell us about your project or what you're looking for..."
                class="w-full px-4 py-2.5 border border-gray-300 rounded-md text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-green-600 focus:border-transparent transition resize-y"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-green-700 hover:bg-green-800 text-white font-semibold px-8 py-3 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2"
            >
              Send Message
            </button>

            <p class="text-xs text-gray-400 text-center mt-4">
              Fields marked with <span class="text-red-500" aria-hidden="true">*</span> <span class="sr-only">(asterisk)</span> are required.
            </p>
          </form>
        </div>
      </div>
    </section>

    <!-- Contact Info Cards -->
    <section class="bg-white">
      <div class="max-w-4xl mx-auto px-4 py-16 md:py-20">
        <div class="text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-green-800 mb-3">Other Ways to Reach Us</h2>
          <p class="text-gray-600">Prefer to call or email directly? We'd love to hear from you.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Call card -->
          
          <a  href="tel:6035550142"
            class="group bg-gray-50 hover:bg-green-700 border border-gray-200 hover:border-green-700 rounded-xl p-8 flex items-center gap-6 transition-colors focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2"
          >
            <div class="w-14 h-14 bg-green-100 group-hover:bg-green-600 rounded-full flex items-center justify-center shrink-0 transition-colors">
              <svg class="w-7 h-7 text-green-700 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-green-700 group-hover:text-green-200 transition-colors mb-1">Call Us</p>
              <h3 class="text-xl font-bold text-gray-800 group-hover:text-white transition-colors">(603) 555-0142</h3>
              <p class="text-sm text-gray-500 group-hover:text-green-200 transition-colors mt-1">Mon–Fri 7am–5pm, Sat 8am–12pm</p>
            </div>
          </a>

          <!-- Email card -->
          
          <a  href="mailto:info@ncLawnlandscape.example.com"
            class="group bg-gray-50 hover:bg-green-700 border border-gray-200 hover:border-green-700 rounded-xl p-8 flex items-center gap-6 transition-colors focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2"
          >
            <div class="w-14 h-14 bg-green-100 group-hover:bg-green-600 rounded-full flex items-center justify-center shrink-0 transition-colors">
              <svg class="w-7 h-7 text-green-700 group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-green-700 group-hover:text-green-200 transition-colors mb-1">Email Us</p>
              <h3 class="text-xl font-bold text-gray-800 group-hover:text-white transition-colors break-all">info@ncLawnlandscape.example.com</h3>
              <p class="text-sm text-gray-500 group-hover:text-green-200 transition-colors mt-1">We'll respond within one business day</p>
            </div>
          </a>

          <!-- Hours card -->
          <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 flex items-center gap-6">
            <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-widest text-green-700 mb-2">Hours</h3>
              <ul class="text-gray-700 text-sm space-y-1">
                <li class="flex gap-4"><span class="w-28">Mon – Fri</span><span>7am – 5pm</span></li>
                <li class="flex gap-4"><span class="w-28">Saturday</span><span>8am – 12pm</span></li>
                <li class="flex gap-4"><span class="w-28">Sunday</span><span>Closed</span></li>
              </ul>
            </div>
          </div>

          <!-- Service Area card -->
          <div class="bg-gray-50 border border-gray-200 rounded-xl p-8 flex items-center gap-6">
            <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-7 h-7 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xs font-semibold uppercase tracking-widest text-green-700 mb-2">Service Area</h3>
              <p class="text-gray-700 text-sm">Proudly serving Littleton and surrounding North Country communities.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-700">
      <div class="max-w-6xl mx-auto px-4 py-16 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Ready to Get Started?
        </h2>
        <p class="text-green-100 mb-8 max-w-xl mx-auto">
          Give us a call or send an email to schedule your free estimate today.
        </p>
        
        <a  href="tel:6035550142"
          class="inline-flex items-center gap-2 bg-white text-green-800 font-semibold px-6 py-3 rounded-md hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-green-700"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (603) 555-0142
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>