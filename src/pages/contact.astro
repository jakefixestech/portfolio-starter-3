---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | North Country Lawn & Landscape" description="Get in touch with North Country Lawn & Landscape for a free estimate on lawn care and landscaping services in Littleton, NH.">
  <!-- Header -->
  <!-- Header -->
  <header class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label="North Country Lawn & Landscape - Home">
        <svg class="w-8 h-8 text-green-700" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
        <span class="font-bold text-lg text-green-800">North Country Lawn & Landscape</span>
      </a>
      <nav aria-label="Main navigation" class="hidden md:flex items-center gap-6">
        <a href="/" class="text-green-700 font-medium">Home</a>
        <a href="/services" class="text-gray-600 hover:text-green-700">Services</a>
        <a href="/contact" class="text-gray-600 hover:text-green-700">Contact</a>
      </nav>
      <button id="menu-btn" aria-label="Open navigation menu" class="md:hidden flex flex-col gap-1.5 p-2">
        <span class="block w-6 h-0.5 bg-green-800"></span>
        <span class="block w-6 h-0.5 bg-green-800"></span>
        <span class="block w-6 h-0.5 bg-green-800"></span>
      </button>
    </div>
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white px-4 py-4 flex flex-col gap-4">
      <a href="/" class="text-green-700 font-medium">Home</a>
      <a href="/services" class="text-gray-600 hover:text-green-700">Services</a>
      <a href="/contact" class="text-gray-600 hover:text-green-700">Contact</a>
    </div>
  </header>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>

  <main>
    <!-- Page Header -->
    <section class="bg-green-800">
      <div class="max-w-6xl mx-auto px-4 py-16 md:py-20 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Contact Us
        </h1>
        <p class="text-green-100 text-lg max-w-2xl mx-auto text-pretty">
          Get in touch for a free estimate.
        </p>
      </div>
    </section>

    <!-- Contact Info Section -->
    <section class="bg-white">
      <div class="max-w-4xl mx-auto px-4 py-16 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Phone -->
          <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 flex items-start gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Phone</h3>
              <a href="tel:6035550142" class="text-green-700 hover:text-green-800 font-medium">
                (603) 555-0142
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 flex items-start gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Email</h3>
              <a href="mailto:info@ncLawnlandscape.example.com" class="text-green-700 hover:text-green-800 font-medium break-all">
                info@ncLawnlandscape.example.com
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 flex items-start gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Hours</h3>
              <ul class="text-gray-600 text-sm space-y-1">
                <li>Monday - Friday: 7am - 5pm</li>
                <li>Saturday: 8am - 12pm</li>
                <li>Sunday: Closed</li>
              </ul>
            </div>
          </div>

          <!-- Service Area -->
          <div class="bg-gray-50 rounded-lg p-6 border border-gray-200 flex items-start gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-green-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-800 mb-1">Service Area</h3>
              <p class="text-gray-600 text-sm">
                Proudly serving Littleton and surrounding North Country communities.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-green-700">
      <div class="max-w-6xl mx-auto px-4 py-16 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Ready to Get Started?
        </h2>
        <p class="text-green-100 mb-8 max-w-xl mx-auto">
          Give us a call or send an email to schedule your free estimate today.
        </p>
        <a
          href="tel:6035550142"
          class="inline-flex items-center gap-2 bg-white text-green-800 font-semibold px-6 py-3 rounded-md hover:bg-gray-100"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (603) 555-0142
        </a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-100 border-t border-gray-200">
    <div class="max-w-6xl mx-auto px-4 py-8 text-center">
      <p class="text-gray-600 text-sm">
        &copy; 2026 North Country Lawn & Landscape. All rights reserved.
      </p>
      <p class="text-gray-500 text-sm mt-1">
        Serving Littleton, NH and the North Country
      </p>
    </div>
  </footer>
</Layout>
